# Copy to .env and fill real values before `docker compose up`.

# Postgres
POSTGRES_USER=recon
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=recon

# Connection URLs (consumed by api + worker)
DATABASE_URL=postgresql+psycopg://recon:change-me-postgres@db:5432/recon
REDIS_URL=redis://redis:6379/0

# Bearer token required to call the API
API_TOKEN=change-me-api-token

# Host ports (loopback). Change if these collide with something local.
API_HOST_PORT=8000
WEB_HOST_PORT=8080

# Fernet master key used to encrypt stored target credentials.
# Generate a real one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-real-fernet-key
